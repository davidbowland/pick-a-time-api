### Get choices for session
# Returns all restaurant choices discovered by the async Google Places lookup.
# Only available after the session is ready (isReady=true).

GET https://{{choosee-api-host}}/v1/sessions/fuzzy-penguin/choices HTTP/1.1

# Response 200:
# {
#   "choice-a": {
#     "choiceId": "choice-a",
#     "name": "Joe's Pizza",
#     "formattedAddress": "123 Main St, Columbia, MO 65203",
#     "formattedPhoneNumber": "(573) 555-1234",
#     "internationalPhoneNumber": "+15735551234",
#     "priceLevel": "PRICE_LEVEL_MODERATE",
#     "rating": 4.5,
#     "ratingsTotal": 200,
#     "distanceMiles": 1.2,
#     "photos": ["https://maps.googleapis.com/..."],
#     "openHours": ["Monday: 11:00 AM – 10:00 PM"],
#     "openNow": true,
#     "isClosingSoon": false,
#     "types": ["Pizza", "Italian"],
#     "website": "https://joespizza.example.com"
#   },
#   "choice-b": { ... }
# }
#
# openNow: present when Google provided a value; true = open now, false = closed.
# isClosingSoon: true when the restaurant is currently open but closes within the next hour.
#   Computed at session-creation time. Always false when filterClosingSoon=true (those
#   places were already removed). Always false when openNow is false or unknown.
#
# Response 404: session not found

