#   "participantCount": 2,
#   "slots": [
#     [
#       { "slotIndex": 0, "startMinute": 960, "endMinute": 1020 },
#       { "slotIndex": 1, "startMinute": 990, "endMinute": 1050 },
#       { "slotIndex": 2, "startMinute": 1020, "endMinute": 1080 }
#     ],
#     [
#       { "slotIndex": 0, "startMinute": 960, "endMinute": 1020 },
#       { "slotIndex": 1, "startMinute": 990, "endMinute": 1050 },
#       { "slotIndex": 2, "startMinute": 1020, "endMinute": 1080 }
