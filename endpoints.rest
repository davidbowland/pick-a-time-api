### Create a plan
# Authenticated variant: POST {{host}}/sessions/authed (Cognito JWT)

POST {{host}}/sessions
Content-Type: application/json
x-recaptcha-token: test-token

{
  "name": "Fall rec soccer practice",
  "weekdays": [4, 5, 6],
  "startDate": "2025-09-04",
  "weekCount": 6,
  "startHour": 16,
  "endHour": 20,
  "timezone": "America/Chicago"
}

# Response 201:
# { "sessionId": "spring-owl" }
#
# Response 400: missing name, empty weekdays, invalid weekCount, etc.
# Response 403: reCAPTCHA score too low

###

### Get plan by ID
GET {{host}}/sessions/{{sessionId}}

# Response 200:
# {
#   "sessionId": "spring-owl",
#   "name": "Fall rec soccer practice",
#   "weekdays": [4, 5, 6],
#   "startDate": "2025-09-04",
#   "weekCount": 6,
#   "startHour": 16,
#   "endHour": 20,
#   "timezone": "America/Chicago",
#   "users": ["brave-tiger", "clever-fox"],
#   "expiration": 1725453600
# }
#
# Response 404: session not found or expired

###

### Get users for plan

GET {{host}}/sessions/{{sessionId}}/users

# Response 200:
# [
#   {
#     "userId": "brave-tiger",
#     "name": "Alice",
#     "phone": "+15551234567",
#     "expiration": 1725453600
#   },
#   {
#     "userId": "clever-fox",
#     "name": "Bob",
#     "phone": null,
#     "expiration": 1725453600
#   }
# ]
#
# Response 404: session not found or expired

###

### Join a plan
# Authenticated variant: POST {{host}}/sessions/{{sessionId}}/users/authed (Cognito JWT)

POST {{host}}/sessions/{{sessionId}}/users

# Response 201:
# {
#   "userId": "clever-fox",
#   "name": null,
#   "phone": null,
#   "expiration": 1725453600
# }
#
# Response 400: max users reached (message includes limit)
# Response 404: session not found or expired

###

### Update user info (name, phone)
# JSON Patch format. Allowed ops: replace.
# Allowed paths: /name, /phone
# Authenticated variant: PATCH {{host}}/sessions/{{sessionId}}/users/{{userId}}/authed (Cognito JWT)

PATCH {{host}}/sessions/{{sessionId}}/users/{{userId}}
Content-Type: application/json

[
  { "op": "replace", "path": "/name", "value": "Alice" }
]

# Example: set phone
# [{ "op": "replace", "path": "/phone", "value": "+15551234567" }]
#
# Response 200: updated user object
# Response 400: disallowed path, name > 50 chars, invalid phone
# Response 404: session or user not found

###

### Get availability
GET {{host}}/sessions/{{sessionId}}/users/{{userId}}/availability

# Response 200:
# {
#   "userId": "brave-tiger",
#   "availability": [
#     [
#       { "hourIndex": 0, "dayIndex": 0, "value": null },
#       { "hourIndex": 0, "dayIndex": 1, "value": null },
#       ...
#     ]
#   ]
# }
#
# Response 404: session or user not found

###

### Paint the template
PATCH {{host}}/sessions/{{sessionId}}/users/{{userId}}/availability
Content-Type: application/json

{
  "weekIndex": null,
  "cells": [{ "hourIndex": 2, "dayIndex": 0, "value": true }],
  "resetToPattern": false
}

# Response 200: updated availability grid
# Response 400: invalid weekIndex, cells, or resetToPattern
# Response 404: session or user not found

###

### Share plan via SMS
# Creates a new user with the recipient's phone and sends an SMS with a join link.
# Requires Cognito JWT. The caller's Google sub must match the sharing user's sub.
# Path includes the sharing user's ID for rate-limit tracking and ownership verification.

POST {{host}}/sessions/{{sessionId}}/users/{{userId}}/share
Content-Type: application/json
Authorization: Bearer {{cognito-jwt}}

{
  "phone": "+15559876543",
  "type": "text"
}

# Response 201:
# { "userId": "clever-fox" }
#
# Response 400: invalid phone format, max users reached
# Response 401: missing or invalid JWT
# Response 403: caller's Google sub doesn't match sharing user, or user not linked
# Response 404: session not found, sharing user not found, or expired
# Response 422: phone number already in use in this session
# Response 429: SMS rate limit exceeded (5 texts per user)
# Response 500: SMS send failed (userId of created user included in error body)
